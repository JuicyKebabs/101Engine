//===========================================================
//頂点シェーダー、ピクセルシェーダー共通の定義
//============================================================
//頂点シェーダー出力データ構造体
struct VSOutPut
{
    float4 svpos : SV_POSITION; //システム用頂点座標
    float4 color : COLOR;       //頂点カラー
    float2 uv : TEXCOORD;       //uv座標
    float3 normal : NORMAL;     //法線ベクトル
};